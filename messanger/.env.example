# Required (build + runtime)
NEXT_PUBLIC_SITE_URL=https://example.com

# GitHub repository used for live repository metrics.
GITHUB_REPO_OWNER=grewanderer
GITHUB_REPO_NAME=animus_coder
# Branch used for branch-status/commit-change metrics.
GITHUB_METRICS_BRANCH=main-work
# Branch used to resolve current release.
GITHUB_RELEASE_BRANCH=main
# Optional observatory thresholds.
# TOKENS_STALE_HOURS=24
# TOKEN_BUDGET_24H=200000
# TOKEN_BUDGET_7D=1200000
# WORKFLOW_TARGET_DURATION_SECONDS=1800
# PR_LEAD_TIME_TARGET_HOURS=24
# METRICS_REFRESH_SECONDS=60
# TOKENS_REFRESH_SECONDS=60
# METRICS_CLIENT_REFRESH_SECONDS=60

# Strongly recommended for production to avoid GitHub API rate-limit gaps in metrics.
# GITHUB_TOKEN=ghp_xxx

# External tokens publisher repository (separate project).
TOKENS_REPO_OWNER=your-org
TOKENS_REPO_NAME=metrics-publisher
TOKENS_FILE_PATH=metrics/token_usage_snapshots.json
# TOKENS_FILE_REF=main-work

# Optional runtime override for persisted local Link chat state.
# ANIMUS_MESSENGER_STATE_FILE=.animus-link/messenger-web/state.json
